---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404: Telemetry Interrupted">
	<main class="error-container">
		<h1>404</h1>
		<div class="accent-line"></div>
		<p>Runtime Error: Requested specification module could not be parsed by the dashboard engine.</p>
		<a href="/GameScript-v1.0S-CL/code-pages/">Return to Mission Control</a>
	</main>
</Layout>

<style>
	.error-container {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		color: #e2e8f0;
		text-align: center;
		background: #050508;
		background-image: linear-gradient(to right, rgba(30, 41, 59, 0.3) 1px, transparent 1px);
		background-size: 32px 32px;
	}
	h1 {
		font-size: 6rem;
		font-family: system-ui, sans-serif;
		margin: 0;
		color: #ff0303;
	}
	.accent-line {
		height: 4px;
		width: 60px;
		background: linear-gradient(90deg, #ff0303, #bc52ee);
		margin: 1rem 0;
	}
	p {
		color: #94a3b8;
		margin-bottom: 2rem;
	}
	a {
		color: #ffffff;
		background: #161b22;
		border: 1px solid rgba(51, 65, 85, 0.5);
		padding: 0.75rem 1.5rem;
		border-radius: 8px;
		text-decoration: none;
	}
	a:hover {
		border-color: #ff0303;
	}
</style>
